# Git LFS configuration for FootsiesGym
# Track binary files with Git LFS

# Game binaries
footsiesgym/binaries/*.zip filter=lfs diff=lfs merge=lfs -text
footsiesgym/binaries/*.x86_64 filter=lfs diff=lfs merge=lfs -text
footsiesgym/binaries/*.so filter=lfs diff=lfs merge=lfs -text
footsiesgym/binaries/*.dll filter=lfs diff=lfs merge=lfs -text
footsiesgym/binaries/*.dylib filter=lfs diff=lfs merge=lfs -text

# Unity data directories (if they contain large files)
footsiesgym/binaries/*_Data/** filter=lfs diff=lfs merge=lfs -text
